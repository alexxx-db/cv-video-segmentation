# For local dev (do NOT commit real secrets)
# If you're on Databricks Apps, you typically don't need these; auth is provided by the runtime.

# For pushing the bundle
# Databricks workspace host, e.g. https://<your-workspace>.cloud.databricks.com
export DATABRICKS_HOST=
export DATABRICKS_TOKEN=

# For the databricks asset bundle
export BUNDLE_VAR_SERVICE_PRINCIPAL_NAME=
export DATABRICKS_BUNDLE_VAR_AUTO_SEGMENT_VOLUME_PATH=

# For local app runtime path resolution
export AUTO_SEGMENT_VOLUME_PATH=


